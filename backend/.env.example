# Application
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=postgresql://cinecraft:cinecraft_dev_password@postgres:5432/cinecraft
# For local SQLite: sqlite:///./cinecraft.db

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET_KEY=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenRouter - Unified AI model access
# Get your API key from: https://openrouter.ai/keys
# Provides access to 100+ AI models including Claude, GPT-4, Gemini, Llama, etc.
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_STORY_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_SCENE_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_CHARACTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Image Generation (add when ready)
# OPENAI_API_KEY=sk-...
# DALLE_API_KEY=...

# Voice Generation (add when ready)
# ELEVENLABS_API_KEY=...

# Music Generation (add when ready)
# SUNO_API_KEY=...

# Stripe
STRIPE_API_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
STRIPE_PRICE_FREE=price_your-free-plan-id
STRIPE_PRICE_PRO=price_your-pro-plan-id
STRIPE_PRICE_ENTERPRISE=price_your-enterprise-plan-id

# Storage
STORAGE_PROVIDER=local  # 'local' or 's3'
LOCAL_STORAGE_PATH=./storage
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_BUCKET_NAME=...
# S3_REGION=us-east-1

# AI Provider Selection
# Options: "anthropic" (direct Anthropic API) or "openrouter" (unified multi-model access)
AI_PROVIDER=anthropic  # 'anthropic', 'openrouter'
IMAGE_PROVIDER=dalle  # 'dalle', 'midjourney', 'stable_diffusion'
VOICE_PROVIDER=elevenlabs  # 'elevenlabs', 'openai_tts'
MUSIC_PROVIDER=suno  # 'suno', 'mubert'

# Feature Flags (defaults)
ENABLE_HD_EXPORT=true
ENABLE_4K_EXPORT=false
ENABLE_API_ACCESS=false

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# FFmpeg
FFMPEG_THREADS=2
FFMPEG_PRESET=medium  # ultrafast, fast, medium, slow
